//+-------------------uglysaint21 on Discord-------------------------+
//|                     Engulfing Pattern EA (MQL5)                  |
//+------------------------------------------------------------------+
#property copyright "OpenAI Example"
#property version   "1.10"
#property strict

#include <Trade\Trade.mqh>

CTrade trade;

// Inputs
input double LotSize      = 0.1;      // lot size
input int    StopLoss     = 200;      // stop loss in points
input int    TakeProfit   = 400;      // take profit in points
input int    MagicNumber  = 12345;    // magic number
input int    MinBars      = 3;        // minimum bars required

//+------------------------------------------------------------------+
//| Check if there are open positions with our magic on this symbol  |
//+------------------------------------------------------------------+
bool PositionOpen()
{
   int total = PositionsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionSelectByTicket(ticket))
      {
         string sym = PositionGetString(POSITION_SYMBOL);
         long   mag = PositionGetInteger(POSITION_MAGIC);
         if(sym == _Symbol && mag == MagicNumber)
            return true;
      }
   }
   return false;
}

//+------------------------------------------------------------------+
//| Ensure we have enough bars to evaluate                            |
//+------------------------------------------------------------------+
bool EnoughBars()
{
   // Need at least MinBars closed bars (index 0 is current forming bar)
   if(Bars(_Symbol, _Period) < MinBars)
      return false;
   return true;
}

//+------------------------------------------------------------------+
//| Detect Bullish Engulfing (uses closed bars: shifts 2 and 1)      |
//+------------------------------------------------------------------+
bool BullishEngulfing()
{
   if(!EnoughBars()) return false;

   double prevOpen  = iOpen(_Symbol, _Period, 2);
   double prevClose = iClose(_Symbol, _Period, 2);
   double currOpen  = iOpen(_Symbol, _Period, 1);
   double currClose = iClose(_Symbol, _Period, 1);

   // previous bearish, current bullish, body of current engulfs body of previous
   if(prevClose < prevOpen &&
      currClose > currOpen &&
      currOpen < prevClose &&
      currClose > prevOpen)
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| Detect Bearish Engulfing                                         |
//+------------------------------------------------------------------+
bool BearishEngulfing()
{
   if(!EnoughBars()) return false;

   double prevOpen  = iOpen(_Symbol, _Period, 2);
   double prevClose = iClose(_Symbol, _Period, 2);
   double currOpen  = iOpen(_Symbol, _Period, 1);
   double currClose = iClose(_Symbol, _Period, 1);

   // previous bullish, current bearish, body of current engulfs body of previous
   if(prevClose > prevOpen &&
      currClose < currOpen &&
      currOpen > prevClose &&
      currClose < prevOpen)
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| Normalize price to symbol digits                                 |
//+------------------------------------------------------------------+
double NormalizePrice(double price)
{
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   return NormalizeDouble(price, digits);
}

//+------------------------------------------------------------------+
//| Return minimal stop level in points (0 if not available)         |
//+------------------------------------------------------------------+
int GetMinStopLevelPoints()
{
   long level = 0;
   if(!SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL, level))
      return 0;
   return (int)level;
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   static datetime lastBarTime = 0;
   datetime currentBarTime = iTime(_Symbol, _Period, 0);

   // run only once per new bar (on bar close)
   if(currentBarTime == lastBarTime)
      return;
   lastBarTime = currentBarTime;

   // ensure enough bars
   if(!EnoughBars())
   {
      PrintFormat("Not enough bars for %s %s", _Symbol, EnumToString(_Period));
      return;
   }

   // do not open if we already have a position with our magic
   if(PositionOpen())
      return;

   // get market prices and symbol info
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);

   if(ask == 0 || bid == 0 || point == 0)
   {
      Print("Price or symbol info unavailable.");
      return;
   }

   // minimal stop level (in points)
   int minStopPoints = GetMinStopLevelPoints();
   if(minStopPoints < 0) minStopPoints = 0;

   // compute SL/TP in price terms and normalize
   double sl = 0.0, tp = 0.0;
   trade.SetExpertMagicNumber((ulong)MagicNumber);

   // BUY SIGNAL
   if(BullishEngulfing())
   {
      // desired SL/TP
      double desiredSL = ask - StopLoss * point;
      double desiredTP = ask + TakeProfit * point;

      // ensure SL distance respects minimal stop level
      double slDistancePoints = (ask - desiredSL) / point;
      if(slDistancePoints < minStopPoints)
      {
         // adjust SL to minimal allowed
         desiredSL = ask - minStopPoints * point;
         PrintFormat("Adjusted buy SL to minimal stop level (%d points).", minStopPoints);
      }

      sl = NormalizePrice(desiredSL);
      tp = NormalizePrice(desiredTP);

      // place market buy (price=0 lets CTrade use market)
      if(!trade.Buy(LotSize, _Symbol, 0, sl, tp, "Bullish Engulfing"))
      {
         PrintFormat("Buy failed (magic=%d): %s [%d]", MagicNumber, trade.ResultRetcodeDescription(), trade.ResultRetcode());
      }
      else
      {
         PrintFormat("Buy placed: %s lots at market, SL=%.%df TP=%.%df", DoubleToString(LotSize,2), digits, sl, tp);
      }
   }

   // SELL SIGNAL
   if(BearishEngulfing())
   {
      double desiredSL = bid + StopLoss * point;
      double desiredTP = bid - TakeProfit * point;

      double slDistancePoints = (desiredSL - bid) / point;
      if(slDistancePoints < minStopPoints)
      {
         desiredSL = bid + minStopPoints * point;
         PrintFormat("Adjusted sell SL to minimal stop level (%d points).", minStopPoints);
      }

      sl = NormalizePrice(desiredSL);
      tp = NormalizePrice(desiredTP);

      if(!trade.Sell(LotSize, _Symbol, 0, sl, tp, "Bearish Engulfing"))
      {
         PrintFormat("Sell failed (magic=%d): %s [%d]", MagicNumber, trade.ResultRetcodeDescription(), trade.ResultRetcode());
      }
      else
      {
         PrintFormat("Sell placed: %s lots at market, SL=%.%df TP=%.%df", DoubleToString(LotSize,2), digits, sl, tp);
      }
   }
}

//+------------------------------------------------------------------+
//| OnInit                                                            |
//+------------------------------------------------------------------+
int OnInit()
{
   // basic validation
   if(LotSize <= 0.0)
   {
      Print("Invalid LotSize. Set to 0.1 by default.");
   }
   if(StopLoss <= 0 || TakeProfit <= 0)
   {
      Print("StopLoss/TakeProfit must be positive integers (points).");
      return(INIT_FAILED);
   }
   PrintFormat("Engulfing EA initialized on %s %s (Magic=%d)", _Symbol, EnumToString(_Period), MagicNumber);
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| OnDeinit                                                          |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   Print("Engulfing EA deinitialized.");
}
//+------------------------------------------------------------------+
